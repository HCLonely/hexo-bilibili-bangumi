// hexo-bilibili-bangumi-assets-start
if pagination
    if swupCompatible
        script(src="https://pugjs.org/js/pug.js" data-swup-reload-script='')
    else
        script(src="https://pugjs.org/js/pug.js")

style
    include index.css
    if theme
        case theme
            when 'fluid'
                include theme/fluid.min.css
            when 'nexmoe'
                include theme/nexmoe.min.css
// hexo-bilibili-bangumi-assets-end

.bangumi-container(class='bangumi-theme-' + pageTheme)
    if quote
        blockquote.bangumi-quote
            p!= quote

    .bangumi-tabs
        a#bangumi-tab1.bangumi-tab(href="javascript:;" rel="external" target="_self" onclick="return false")
            | #{__(type === 'game' ? 'wantPlay' : 'wantWatch')}
            | (#{wantWatch.length})
        a#bangumi-tab2.bangumi-tab(href="javascript:;" rel="external" target="_self" onclick="return false")
            | #{__(type === 'game' ? 'playing' : 'watching')}
            | (#{watching.length})
        a#bangumi-tab3.bangumi-tab(href="javascript:;" rel="external" target="_self" onclick="return false")
            | #{__(type === 'game' ? 'played' : 'watched')}
            | (#{watched.length})

    div
        #bangumi-item1
            if pagination
                each item in wantWatch.slice(0, 10)
                    case source
                        when 'bili'
                            include bili-template.pug
                        when 'bgmv0'
                            include bgmv0-template.pug
                        when 'bgm'
                            include bgm-template.pug
                        when 'bangumi'
                            include bangumi-template.pug
                        when 'anilist'
                            include anilist-template.pug
                        when 'simkl'
                            include simkl-template.pug
                include pagination.pug
            else
                each item in wantWatch
                    case source
                        when 'bili'
                            include bili-template.pug
                        when 'bgmv0'
                            include bgmv0-template.pug
                        when 'bgm'
                            include bgm-template.pug
                        when 'bangumi'
                            include bangumi-template.pug
                        when 'anilist'
                            include anilist-template.pug
                        when 'simkl'
                            include simkl-template.pug
                include pagination.pug

        #bangumi-item2
            if pagination
                each item in watching.slice(0, 10)
                    case source
                        when 'bili'
                            include bili-template.pug
                        when 'bgmv0'
                            include bgmv0-template.pug
                        when 'bgm'
                            include bgm-template.pug
                        when 'bangumi'
                            include bangumi-template.pug
                        when 'anilist'
                            include anilist-template.pug
                        when 'simkl'
                            include simkl-template.pug
                include pagination.pug
            else
                each item in watching
                    case source
                        when 'bili'
                            include bili-template.pug
                        when 'bgmv0'
                            include bgmv0-template.pug
                        when 'bgm'
                            include bgm-template.pug
                        when 'bangumi'
                            include bangumi-template.pug
                        when 'anilist'
                            include anilist-template.pug
                        when 'simkl'
                            include simkl-template.pug
                include pagination.pug

        #bangumi-item3
            if pagination
                each item in watched.slice(0, 10)
                    case source
                        when 'bili'
                            include bili-template.pug
                        when 'bgmv0'
                            include bgmv0-template.pug
                        when 'bgm'
                            include bgm-template.pug
                        when 'bangumi'
                            include bangumi-template.pug
                        when 'anilist'
                            include anilist-template.pug
                        when 'simkl'
                            include simkl-template.pug
                include pagination.pug
            else
                each item in watched
                    case source
                        when 'bili'
                            include bili-template.pug
                        when 'bgmv0'
                            include bgmv0-template.pug
                        when 'bgm'
                            include bgm-template.pug
                        when 'bangumi'
                            include bangumi-template.pug
                        when 'anilist'
                            include anilist-template.pug
                        when 'simkl'
                            include simkl-template.pug
                include pagination.pug

// hexo-bilibili-bangumi-assets-start
if swupCompatible
    script(data-swup-reload-script='')
        include index.js
        include pagination.js
    script(data-swup-reload-script='').
        function renderBilibiliBangumi() {
            if (!window.hexoBilibiliBangumiOptions) {
                window.hexoBilibiliBangumiOptions = {
                    bangumiLazyload: #{!!lazyload},
                    show: #{show}
                }
            }
            if (#{pagination} && !document.querySelectorAll('.bangumi-tabs')[0].getAttribute('pagination')) {
                document.querySelectorAll('.bangumi-tabs')[0].setAttribute('pagination', 'true');
                window.hexoBilibiliBangumiOptions.pugTemplate = `!{pugTemplate}`;
                window.hexoBilibiliBangumiOptions.pugOptions = {
                    metaColor: '#{metaColor}',
                    type: '#{type}',
                    color: '#{color}',
                    lazyload: #{!!lazyload},
                    showMyComment: #{showMyComment},
                    srcValue: '#{srcValue}'
                }
                window.hexoBilibiliBangumiOptions.pagenumsPre = #{JSON.stringify([wantWatch.length, watching.length, watched.length])};
                (function waitForPug() {
                    if (typeof require !== 'undefined' && require('pug')) {
                        window.hexoBilibiliBangumiOptions.pug = require('pug');
                        initPagination();
                        pagination();
                    } else {
                        setTimeout(waitForPug, 100);
                    }
                })();
            } else {
                initPagination();
                pagination();
            }
        }
        document.addEventListener('DOMContentLoaded', renderBilibiliBangumi);
        window.addEventListener('pjax:complete', renderBilibiliBangumi);
else
    script
        include index.js
        include pagination.js
